# --- Firebird connection (single configured DB) ---
firebird.host=localhost
firebird.port=3050
firebird.database=C:\path\to\your\DATABASE.FDB
firebird.user=SYSDBA
firebird.password=masterkey
firebird.charset=UTF8
# Point this at the fbclient.dll matching YOUR Firebird server's version;
# its folder should also contain isql.exe (a full server install has both).
firebird.client_lib=C:\Program Files\Firebird\Firebird_5_0\fbclient.dll
# --- Logging (file only; stdout stays pure JSON-RPC for stdio) ---
logger.config.file=loggerpro.stdio.json
