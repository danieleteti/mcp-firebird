**/.env
!**/.env.example

# Logs
logs/
*.log

# Python test cache
__pycache__/
.pytest_cache/

# Firebird zip-kits (local install, not versioned)
fb_versions/

# Generated seed database (built locally by tests/seed/make_seed.ps1)
tests/seed/*.FDB
